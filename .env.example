SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
SUPABASE_STATEMENTS_TABLE=statements
SUPABASE_STATEMENTS_DATE_COLUMN=transaction_date
SUPABASE_STATEMENTS_ACCOUNT_COLUMN=account_no

# Google Drive OAuth (preferred). Create an OAuth client in Google Cloud Console
# and set the redirect URI to <APP_URL>/api/google/oauth/callback.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://your-app.example.com/api/google/oauth/callback

# Per-purpose Drive folder IDs. Files uploaded with folderType=slip/statement/payout_time
# will be placed inside the matching folder. Leave blank to upload into "My Drive" root.
GOOGLE_DRIVE_FOLDER_SLIPS=
GOOGLE_DRIVE_FOLDER_STATEMENTS=
GOOGLE_DRIVE_FOLDER_PAYOUT_TIME=

# Optional fallback folder used when no specific folder is set for a folderType.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_MAX_UPLOAD_BYTES=20971520

GO2PAY_ADMIN_TOKEN=replace-with-cookie-token
GO2PAY_API_BASE=https://api.go2pay.tech/api/admin

TELEGRAM_BOT_TOKEN=replace-with-token
TELEGRAM_TRANSFER_CHAT_ID=
TELEGRAM_TRANSFER_THREAD_ID=
TELEGRAM_CRYPTO_CHAT_ID=
TELEGRAM_CRYPTO_THREAD_ID=
TELEGRAM_TICKET_CHAT_ID=
TELEGRAM_TICKET_THREAD_ID=
TELEGRAM_TOKEN_ALERT_CHAT_ID=
TELEGRAM_TOKEN_ALERT_THREAD_ID=

CRON_SECRET=replace-with-random-secret
